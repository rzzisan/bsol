# Copy these values into Dokploy project/service environment variables.
# Keep real secrets only inside Dokploy, not in git.

DOKPLOY_DOMAIN=example.com
NEXT_PUBLIC_APP_NAME="Hybrid Stack SaaS"
NEXT_PUBLIC_API_BASE_URL="https://example.com/api"

APP_NAME="Hybrid Stack SaaS"
APP_ENV=production
APP_DEBUG=false
APP_URL="https://example.com"
APP_KEY="base64:GENERATE_A_REAL_APP_KEY"
FRONTEND_URL="https://example.com"
LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=your-postgres-host
DB_PORT=5432
DB_DATABASE=hybrid_platform
DB_USERNAME=hybrid_app
DB_PASSWORD=replace_me
DB_SSLMODE=prefer

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=example.com
SANCTUM_STATEFUL_DOMAINS=example.com

REDIS_CLIENT=phpredis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

RUN_MIGRATIONS=false
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=90
